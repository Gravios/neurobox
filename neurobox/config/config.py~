    web.mkdir(parents=True,exist_ok=True)
    scripts.mkdir(parents=True,exist_ok=True)
    classifiers.mkdir(parents=True,exist_ok=True)
    models.mkdir(parents=True,exist_ok=True)
    data.mkdir(parents=True,exist_ok=True)


