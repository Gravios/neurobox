import os
import numpy as np
from pathlib import Path
from neurobox.utils import copytree
from dotenv import dotenv_values


def configure_project(dotenv_path, overwrite=False):

    os.chdir(Path(dotenv_path))
    
    project_conf = dotenv_values()

    project_name  = project_conf["NB_PROJECT_NAME"]
    NB_PROJECT_PATH  = Path(project_conf["NB_PROJECT_PATH"]) / project_name

    NB_PATH          = Path(project_conf["NB_PATH"])
    NB_DATA_PATH     = Path(project_conf["NB_DATA_PATH"])
    NB_NOTEBOOK_PATH = Path(project_conf["NB_NOTEBOOK_PATH"])
    NB_FIGURES_PATH  = Path(project_conf["NB_FIGURES_PATH"])
    
    if NB_PATH is None:
        raise ValueError("neurobox.config: environmental variable NB_PATH has not been set.")
    if NB_DATA_PATH is None:
        raise ValueError("neurobox.config: environmental variable NB_DATA_PATH has not been set.")
    if NB_PROJECT_PATH is None:
        raise ValueError("neurobox.config: environmental variable NB_PROJECT_PATH has not been set.")        
    if NB_FIGURES_PATH is None:
        raise ValueError("neurobox.config: environmental variable NB_FIGURES_PATH has not been set.")        

    # SETUP paths
    neurobox    = NB_PATH / "neurobox"
    data        = NB_DATA_PATH
    
    cfg         = NB_PROJECT_PATH / "config"    
    arm         = NB_PROJECT_PATH / "arm"
    web         = NB_PROJECT_PATH / "web"
    scripts     = NB_PROJECT_PATH / "scripts"
    classifiers = NB_PROJECT_PATH / "python" / "classifiers"
    models      = NB_PROJECT_PATH / "models"

    
    cfg.mkdir(parents=True,exist_ok=True)
    neurobox.mkdir(parents=True,exist_ok=True)
